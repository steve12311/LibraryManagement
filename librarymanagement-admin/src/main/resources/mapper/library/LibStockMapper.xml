<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.dwtech.mapper.LibStockMapper">
    <resultMap id="LibStockResult" type="LibBookStockDao">
        <id property="bookId" column="book_id"/>
        <result property="isbn" column="isbn"/>
        <result property="price" column="price"/>
        <result property="bookName" column="book_name"/>
        <result property="bookImage" column="book_image"/>
        <result property="author" column="author"/>
        <result property="publishId" column="publish_id"/>
        <result property="publishName" column="publish_name"/>
        <result property="publishTime" column="publish_time"/>
        <result property="categoryId" column="category_id"/>
        <result property="categoryName" column="category_name"/>
        <result property="stockNumber" column="stock_number"/>
        <result property="currentNumber" column="current_number"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectStockVo">
        select bk.book_id,
               bk.isbn,
               bk.price,
               bk.book_name,
               bk.book_image,
               bk.author,
               bk.publish_id,
               bk.category_id,
               bk.publish_time,
               bp.publish_name,
               bc.category_name,
               bs.stock_number,
               bs.current_number,
               bs.create_by,
               bs.create_time,
               bs.update_by,
               bs.update_time,
               bs.remark
        from lib_book bk
                 left join lib_book_publish bp on bp.publish_id = bk.publish_id
                 left join lib_book_category bc on bc.category_id = bk.category_id
                 left join lib_book_stock bs on bs.book_id = bk.book_id
    </sql>

    <select id="selectStockList" parameterType="LibBookStockDto" resultMap="LibStockResult">
        <include refid="selectStockVo"/>
        <where>
            <if test="libBookStockDao.bookId != null and libBookStockDao.bookId != 0">and book_id = #{bookId}</if>
            <if test="libBookStockDao.isbn != null and libBookStockDao.isbn != ''">and isbn = #{isbn}</if>
            <if test="libBookStockDao.price != null and libBookStockDao.price != 0">and price = #{price}</if>
            <if test="libBookStockDao.bookName != null and libBookStockDao.bookName !=''">and book_name = #{bookName}
            </if>
            <if test="libBookStockDao.bookImage != null and libBookStockDao.bookImage != ''">and book_image =
                #{bookImage}
            </if>
            <if test="libBookStockDao.author != null and libBookStockDao.author != ''">and author = #{author}</if>
            <if test="libBookStockDao.publishId != null and libBookStockDao.publishId != 0">and publish_id =
                #{publishId}
            </if>
            <if test="libBookStockDao.publishTime != null and libBookStockDao.publishTime != ''">and publish_time =
                #{publishTime}
            </if>
            <if test="libBookStockDao.categoryId != null and libBookStockDao.categoryId != 0">and category_id =
                #{categoryId}
            </if>
            <if test="libBookStockDao.stockNumber != null">and stock_number = #{stockNumber}</if>
            <if test="libBookStockDao.currentNumber != null">and current_number = #{currentNumber}</if>
            <if test="libBookStockDao.createTime != null and libBookStockDao.createTime != ''">and create_time =
                #{createTime}
            </if>
            <if test="libBookStockDao.updateTime != null and libBookStockDao.updateTime != ''">and update_time =
                #{updateTime}
            </if>
            <if test="libBookStockDao.remark != null and libBookStockDao.remark != ''">and remark = #{remark}</if>
        </where>
    </select>

    <select id="selectStockListByBookIds" parameterType="Long">
        <include refid="selectStockVo"/>
        where bk.book_id in
        <foreach collection="array" item="bookId" open="(" separator="," close=")">
            #{bookId}
        </foreach>
    </select>

    <select id="selectStockByIsbn" parameterType="String">
        <include refid="selectStockVo"/>
        where bk.isbn = #{isbn}
    </select>

    <insert id="insertStock" parameterType="LibBookStockDto">
        insert into lib_book(
        <if test="bookId != null and bookId != 0">book_id,</if>
        <if test="isbn != null and isbn != ''">isbn,</if>
        <if test="bookName != null and bookName != ''">book_name,</if>
        <if test="price != null and price != 0">price,</if>
        <if test="bookImage != null and bookImage != ''">book_image,</if>
        <if test="author != null and author != ''">author,</if>
        <if test="publishId != null and publishId != 0">publish_id,</if>
        <if test="categoryId != null and categoryId != 0">category_id,</if>
        <if test="publishTime != null and publishTime != ''">publish_time,</if>
        <if test="createBy != null and createBy != ''">create_by,</if>
        <if test="remark != null and remark != ''">remark,</if>
        create_time
        )values (
        <if test="bookId != null and bookId != 0">#{bookId},</if>
        <if test="isbn != null and isbn != ''">#{isbn},</if>
        <if test="bookName != null and bookName != ''">#{bookName},</if>
        <if test="price != null and price != 0">#{price},</if>
        <if test="bookImage != null and bookImage != ''">#{bookImage},</if>
        <if test="author != null and author != ''">#{author},</if>
        <if test="publishId != null and publishId != 0">#{publishId},</if>
        <if test="categoryId != null and categoryId != 0">#{categoryId},</if>
        <if test="publishTime != null and publishTime != ''">#{publishTime},</if>
        <if test="createBy != null and createBy != ''">#{createBy},</if>
        <if test="remark != null and remark != ''">#{remark},</if>
        sysdate()
        );
        insert into lib_book_stock(
        <if test="stockId != null and stock != 0">stock_id,</if>
        book_id,
        <if test="stockNumber != null and stockNumber != 0">stock_number,</if>
        <if test="currentNumber != null and currentNumber != 0">current_number,</if>
        <if test="createBy != null and createBy != ''">create_by,</if>
        <if test="remark != null and remark != ''">remark,</if>
        create_time
        )values(
        <if test="stockId != null and stock != 0">stock_id,</if>
        (select book_id from lib_book where isbn = #{isbn}),
        <if test="stockNumber != null and stockNumber != 0">stock_number,</if>
        <if test="currentNumber != null and currentNumber != 0">current_number,</if>
        <if test="createBy != null and createBy != ''">create_by,</if>
        <if test="remark != null and remark != ''">remark,</if>
        sysdate()
        )
    </insert>

    <update id="updateStock">
        update lib_book_stock
        <set>
            <if test="stockNumber != null">stock_number = #{stockNumber},</if>
            current_number = #{currentNumber},
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where book_id = (select book_id from lib_book where isbn = #{isbn})
    </update>
</mapper>