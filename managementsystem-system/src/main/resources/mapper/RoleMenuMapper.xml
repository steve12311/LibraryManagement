<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.dwtech.system.mapper.RoleMenuMapper">
    <!-- 权限和拥有权限的角色的映射 -->
    <resultMap id="PremRolesMap" type="org.dwtech.common.core.entity.bo.RolePermsBO">
        <result property="roleCode" column="role_code"/>
        <collection property="perms" ofType="string" javaType="java.util.Set">
            <result column="perm"/>
        </collection>
    </resultMap>

    <select id="getRolePermsList" resultMap="PremRolesMap">
        SELECT
        t3.perm,
        t2.code role_code
        FROM
        sys_role_menu t1
        INNER JOIN sys_role t2 ON t1.role_id = t2.id AND t2.is_deleted = 0 AND t2.status = 1
        INNER JOIN sys_menu t3 ON t1.menu_id = t3.id
        WHERE
        t3.type = '${@org.dwtech.common.enmus.MenuTypeEnum@BUTTON.getValue()}'
        <if test="roleCode != null and roleCode.trim() neq ''">
            AND t2.code = #{roleCode}
        </if>
    </select>
</mapper>