<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.dwtech.system.mapper.BorrowMapper">
    <sql id="borrowView">
        SELECT bw.id,
               bw.isbn,
               bw.book_name,
               bw.return_time,
               bw.user_id,
               u.nickname,
               u.avatar,
               u.username,
               CASE
                   WHEN bw.reality_return_time IS NOT NULL THEN 0
                   WHEN bw.return_time >= NOW() THEN 1
                   ELSE 2
                   END AS status
        FROM lib_borrow AS bw
                 LEFT JOIN sys_user AS u ON u.id = bw.user_id
    </sql>
    <sql id="myBorrowView">
        SELECT bw.id,
               bw.isbn,
               b.cover,
               bw.book_name,
               bw.return_time,
               CASE
                   WHEN bw.reality_return_time IS NOT NULL THEN 0
                   WHEN bw.return_time >= NOW() THEN 1
                   ELSE 2
                   END AS status
        FROM lib_borrow AS bw
                 LEFT JOIN lib_book AS b ON b.isbn = bw.isbn
    </sql>
    <select id="getBorrowPage" resultType="org.dwtech.system.model.bo.BorrowBO">
        <include refid="borrowView"/>
        <where>
            <if test="queryParams.field != null and queryParams.field != '' and queryParams.keyword != null and queryParams.keyword != ''">
                <choose>
                    <when test="queryParams.field == 'status'">
                        <choose>
                            <!-- 0: 已归还 -->
                            <when test="queryParams.keyword == &quot;0&quot;">
                                AND bw.reality_return_time IS NOT NULL
                            </when>

                            <!-- 1: 借阅中（未归还且未超期） -->
                            <when test="queryParams.keyword == &quot;1&quot;">
                                AND bw.reality_return_time IS NULL
                                AND bw.return_time &gt;= NOW()
                            </when>

                            <!-- 2: 已逾期（未归还且已超过应还时间） -->
                            <when test="queryParams.keyword == &quot;2&quot;">
                                AND bw.reality_return_time IS NULL
                                AND bw.return_time &lt; NOW()
                            </when>
                        </choose>
                    </when>
                    <when test="queryParams.field == 'username'">
                        AND u.username LIKE CONCAT(#{queryParams.keyword}, '%')
                    </when>
                    <when test="queryParams.field == 'isbn'">
                        AND bw.isbn LIKE CONCAT(#{queryParams.keyword}, '%')
                    </when>
                </choose>
            </if>
        </where>
        ORDER BY bw.create_time DESC, bw.id DESC
    </select>
    <select id="getCurrentUserBorrowPage" resultType="org.dwtech.system.model.bo.MyBorrowBO">
        <include refid="myBorrowView"/>
        <where>
            bw.user_id = #{userId}
            <if test="queryParams.status != null">
                <choose>
                    <when test="queryParams.status == 0">
                        AND bw.reality_return_time IS NOT NULL
                    </when>
                    <when test="queryParams.status == 1">
                        AND bw.reality_return_time IS NULL
                        AND bw.return_time &gt;= NOW()
                    </when>
                    <when test="queryParams.status == 2">
                        AND bw.reality_return_time IS NULL
                        AND bw.return_time &lt; NOW()
                    </when>
                </choose>
            </if>
        </where>
        ORDER BY bw.return_time DESC, bw.id DESC
    </select>

    <!-- 查询剩余 N 天到期的未还借阅（定时通知用） -->
    <select id="selectDueSoon" resultType="org.dwtech.system.model.entity.BorrowPO">
        SELECT id, isbn, book_name, user_id, return_time
        FROM lib_borrow
        WHERE reality_return_time IS NULL
          AND DATEDIFF(return_time, CURDATE()) = #{days}
    </select>

    <!-- 查询已逾期的未还借阅（定时通知用） -->
    <select id="selectOverdue" resultType="org.dwtech.system.model.entity.BorrowPO">
        SELECT id, isbn, book_name, user_id, return_time
        FROM lib_borrow
        WHERE reality_return_time IS NULL
          AND return_time &lt; CURDATE()
    </select>

</mapper>
