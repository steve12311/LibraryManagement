<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.dwtech.mapper.LibCategoryMapper">

    <resultMap id="LibCategoryResult" type="LibCategoryPo">
        <id property="categoryId" column="category_id"/>
        <result property="code" column="code"/>
        <result property="parentId" column="parent_id"/>
        <result property="ancestors" column="ancestors"/>
        <result property="categoryName" column="category_name"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectLibCategoryVo">
        select c.category_id,
               c.code,
               c.parent_id,
               c.ancestors,
               c.category_name,
               c.create_by,
               c.update_by,
               c.create_time,
               c.update_time,
               c.remark
        from lib_book_category c
    </sql>

    <select id="selectLibCategoryList" parameterType="LibCategoryPo" resultMap="LibCategoryResult">
        <include refid="selectLibCategoryVo"/>
        <where>
            <if test="categoryId != null and categoryId != 0">
                and c.category_id = #{categoryId}
            </if>
            <if test="code != null and code != ''">
                and c.code = #{code}
            </if>
            <if test="categoryName != null and categoryName != ''">
                and c.category_name like concat('%',#{categoryName},'%')
            </if>
        </where>
    </select>

    <select id="selectLibCategoryByIds" parameterType="Long" resultMap="LibCategoryResult">
        <include refid="selectLibCategoryVo"/>
        where category_id in
        <foreach collection="array" item="categoryId" open="(" separator="," close=")">
            #{categoryId}
        </foreach>
    </select>

    <insert id="insertLibCategory" parameterType="LibCategoryPo">
        insert into lib_book_category(
        <if test="categoryId != null and categoryId != 0">category_id,</if>
        <if test="code != null and code != ''">code,</if>
        <if test="parentId != null and parentId != 0">parent_id,</if>
        <if test="ancestors != null and ancestors != ''">ancestors,</if>
        <if test="categoryName != null and categoryName != ''">category_name,</if>
        <if test="createBy != null and createBy != ''">create_by,</if>
        <if test="remark != null and remark != ''">remark,</if>
        create_time
        )values (
        <if test="categoryId != null and categoryId != 0">#{categoryId},</if>
        <if test="code != null and code != ''">#{code},</if>
        <if test="parentId != null and parentId != 0">#{parentId},</if>
        <if test="ancestors != null and ancestors != ''">#{ancestors},</if>
        <if test="categoryName != null and categoryName != ''">#{categoryName},</if>
        <if test="createBy != null and createBy != ''">#{createBy},</if>
        <if test="remark != null and remark != ''">#{remark},</if>
        sysdate()
        )
    </insert>

    <update id="updateLibCategory" parameterType="LibCategoryPo">
        update lib_book_category
        <set>
            <if test="code != null and code != ''">code = #{code},</if>
            <if test="parentId != null and parentId != 0">parent_id = #{parent_id},</if>
            <if test="ancestors != null and ancestors != ''">ancestors = #{ancestors},</if>
            <if test="categoryName != null and categoryName != ''">category_name = #{categoryName},</if>
            <if test="remark != null and remark != ''">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where category_id = #{categoryId}
    </update>

    <delete id="deleteLibCategoryById" parameterType="Long">
        delete
        from lib_book_category
        where category_id = #{categoryId}
    </delete>
</mapper>